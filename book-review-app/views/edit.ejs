<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h2>Update Book Ratings!</h2>
    <form action="/books/<%= book._id %>?_method=PUT" method="POST" class="new-form">
        <label>Update Ratings</label>
        <input type="number" name="newRating" value="<%= book.rating %>">
        <button type="submit">Update</button>
    </form>
</body>
</html>