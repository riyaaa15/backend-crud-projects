<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Books</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h2>Book Review App!</h2>
    <a href="/books/new" class="add-btn">+ Add More Books!</a>

    <table class="book-table">
        <tr>
            <th>title</th>
            <th>Author</th>
            <th>Genre</th>
            <th>Rating</th>
            <th>actions</th>
        </tr>
        <% for(let b of book) { %>
        <tr>
            <td><%= b.title %></td>
            <td><%= b.author %></td>
            <td><%= b.genre %></td>
            <td class="<%= b.rating >= 8 ? 'green' : b.rating >= 5 ? 'yellow' : 'red' %>">
                <%= b.rating %>
            </td>
             <td class="actions">
                <a class="edit-btn" href="/books/<%= b._id %>/edit">Edit</a>
                <form method="POST" action="/books/<%= b._id %>?_method=DELETE">
                    <button type="submit" class="delete-btn">Delete</button>
                </form>
            </td>
        </tr>
        <% } %>
    </table>
</body>
</html>