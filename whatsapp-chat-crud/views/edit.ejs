<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit your Chat</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <p>Edit your chat: <%= chat._id %></p>
    <p>
        This chat was sent from <b><%= chat.from %></b> to <b><%= chat.to %>
        </b>
    </p>

    <div class="form-container">
        <h3>Edit Message</h3>
        <form method="POST" action="/chats/<%= chat._id %>?_method=PUT" class="chat-form">
            <div class="form-group">
                <label>Message</label>
                <textarea name="newMsg" rows="6"><%= chat.msg %></textarea>
            </div>
            <button class="new-chat">Edit</button>
        </form>
    </div>
</body>
</html>