<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Marks Tracker</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h2><i>Students Marks Tracker</i></h2>
    <a href="/students/new" class="add-btn">+ Add Student</a>

    <table class="student-table">
        <tr>
            <th>Name</th>
            <th>Subject</th>
            <th>Marks</th>
            <th>Result</th>
            <th>Actions</th>
        </tr>
        <% for(let student of data) { %>
        <tr>
            <td><%= student.name %></td>
            <td><%= student.subject %></td>
            <td><%= student.marks %></td>
            <td class="<%= student.marks >= 40 ? 'pass' : 'fail' %>">
                <%= student.marks >= 40 ? 'Pass' : 'Fail' %>
            </td>
            <td class="actions">
                <a class="edit-btn" href="/students/<%= student._id %>/edit">Edit</a>
                <form method="POST" action="/students/<%= student._id %>?_method=DELETE">
                    <button type="submit" class="delete-btn">Delete</button>
                </form>
            </td>
            </tr>
        <% } %>
    </table>
    
</body>
</html>